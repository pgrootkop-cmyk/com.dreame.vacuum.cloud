{
  "name": {
    "en": "Vacuum Map"
  },
  "settings": [
    {
      "id": "colorScheme",
      "type": "dropdown",
      "title": { "en": "Color scheme" },
      "value": "Dreame Light",
      "values": [
        { "id": "Dreame Light", "title": { "en": "Dreame Light" } },
        { "id": "Dreame Dark", "title": { "en": "Dreame Dark" } },
        { "id": "Mijia Light", "title": { "en": "Mijia Light" } },
        { "id": "Mijia Dark", "title": { "en": "Mijia Dark" } },
        { "id": "Grayscale", "title": { "en": "Grayscale" } }
      ]
    },
    {
      "id": "labelSize",
      "type": "dropdown",
      "title": { "en": "Room label size" },
      "value": "medium",
      "values": [
        { "id": "small", "title": { "en": "Small" } },
        { "id": "medium", "title": { "en": "Medium" } },
        { "id": "large", "title": { "en": "Large" } },
        { "id": "xxl", "title": { "en": "XXL" } }
      ]
    },
    {
      "id": "showRoomNames",
      "type": "checkbox",
      "title": { "en": "Show room names" },
      "value": true
    },
    {
      "id": "showStatus",
      "type": "checkbox",
      "title": { "en": "Show status bar" },
      "value": true
    },
    {
      "id": "rotation",
      "type": "dropdown",
      "title": { "en": "Map rotation" },
      "value": "0",
      "values": [
        { "id": "0", "title": { "en": "0°" } },
        { "id": "90", "title": { "en": "90°" } },
        { "id": "180", "title": { "en": "180°" } },
        { "id": "270", "title": { "en": "270°" } }
      ]
    },
    {
      "id": "floor",
      "type": "autocomplete",
      "title": { "en": "Floor" },
      "hint": { "en": "Select which floor map to display (only for multi-floor setups)" }
    }
  ],
  "height": "75%",
  "api": {
    "getDeviceData": {
      "method": "GET",
      "path": "/data"
    },
    "getMapData": {
      "method": "GET",
      "path": "/map"
    },
    "getRobotPosition": {
      "method": "GET",
      "path": "/robot-pos"
    }
  },
  "devices": {
    "singular": true,
    "type": "app",
    "filter": {
      "class": "vacuumcleaner",
      "capabilities": "vacuumcleaner_state"
    }
  }
}
