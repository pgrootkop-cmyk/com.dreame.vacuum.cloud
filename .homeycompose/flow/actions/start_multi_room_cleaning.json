{
  "title": {
    "en": "Clean multiple rooms"
  },
  "titleFormatted": {
    "en": "Clean rooms [[rooms]] at [[suction]] suction, [[water]] water, [[repeats]]x"
  },
  "hint": {
    "en": "Clean multiple rooms. Select rooms one at a time — each selection adds to the list. Use 'All rooms' to clean everything."
  },
  "args": [
    {
      "name": "device",
      "type": "device",
      "filter": "driver_id=vacuum"
    },
    {
      "type": "autocomplete",
      "name": "rooms",
      "title": {
        "en": "Rooms"
      },
      "placeholder": {
        "en": "Search rooms..."
      }
    },
    {
      "type": "dropdown",
      "name": "suction",
      "title": {
        "en": "Suction"
      },
      "values": [
        { "id": "quiet", "title": { "en": "Quiet" } },
        { "id": "standard", "title": { "en": "Standard" } },
        { "id": "strong", "title": { "en": "Strong" } },
        { "id": "turbo", "title": { "en": "Turbo" } }
      ]
    },
    {
      "type": "dropdown",
      "name": "water",
      "title": {
        "en": "Water Volume"
      },
      "values": [
        { "id": "low", "title": { "en": "Low" } },
        { "id": "medium", "title": { "en": "Medium" } },
        { "id": "high", "title": { "en": "High" } }
      ]
    },
    {
      "type": "number",
      "name": "repeats",
      "title": {
        "en": "Repeats"
      },
      "min": 1,
      "max": 3,
      "step": 1
    }
  ]
}
