{
  "title": {
    "en": "Clean room by ID"
  },
  "titleFormatted": {
    "en": "Clean room ID [[room_id]] in [[mode]] mode, [[suction]] suction, [[water]] water, [[repeats]]x"
  },
  "hint": {
    "en": "Start cleaning a room by its numeric ID. Find room IDs in the app settings page."
  },
  "args": [
    {
      "name": "device",
      "type": "device",
      "filter": "driver_id=vacuum"
    },
    {
      "type": "text",
      "name": "room_id",
      "title": {
        "en": "Room ID"
      },
      "placeholder": {
        "en": "e.g. 10"
      }
    },
    {
      "type": "dropdown",
      "name": "mode",
      "title": {
        "en": "Cleaning mode"
      },
      "values": [
        {
          "id": "current",
          "title": {
            "en": "Current setting"
          }
        },
        {
          "id": "sweeping",
          "title": {
            "en": "Sweeping"
          }
        },
        {
          "id": "mopping",
          "title": {
            "en": "Mopping"
          }
        },
        {
          "id": "sweeping_and_mopping",
          "title": {
            "en": "Sweeping & Mopping"
          }
        },
        {
          "id": "mopping_after_sweeping",
          "title": {
            "en": "Vacuum then Mop"
          }
        }
      ]
    },
    {
      "type": "dropdown",
      "name": "suction",
      "title": {
        "en": "Suction"
      },
      "values": [
        {
          "id": "quiet",
          "title": {
            "en": "Quiet"
          }
        },
        {
          "id": "standard",
          "title": {
            "en": "Standard"
          }
        },
        {
          "id": "strong",
          "title": {
            "en": "Strong"
          }
        },
        {
          "id": "turbo",
          "title": {
            "en": "Turbo"
          }
        }
      ]
    },
    {
      "type": "dropdown",
      "name": "water",
      "title": {
        "en": "Water Volume"
      },
      "values": [
        {
          "id": "low",
          "title": {
            "en": "Low"
          }
        },
        {
          "id": "medium",
          "title": {
            "en": "Medium"
          }
        },
        {
          "id": "high",
          "title": {
            "en": "High"
          }
        }
      ]
    },
    {
      "type": "number",
      "name": "repeats",
      "title": {
        "en": "Repeats"
      },
      "min": 1,
      "max": 3,
      "step": 1
    }
  ]
}
